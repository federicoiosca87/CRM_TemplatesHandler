# OAuth 2.0 configuration — EXAMPLE FILE (safe to commit)
# Copy this to .streamlit/secrets.toml and fill in the real values.
# secrets.toml is gitignored and must never be committed.

[oauth]
# IdentityServer authority base URL (no trailing slash)
authority    = "https://YOUR_IDENTITY_SERVER_URL"

# App registration client ID registered in IdentityServer
client_id    = "Tools.CRM_TemplateHandler"

# Client secret — leave empty ("") for public clients using PKCE only
client_secret = ""

# Space-separated list of requested scopes
scopes       = "openid profile IdentityServerApi"

# OAuth redirect URI — must match the registered redirect in IdentityServer.
# For local development use http://localhost:8501.
# Update to QA/prod URL when deploying to other environments.
redirect_uri = "http://localhost:8501"
